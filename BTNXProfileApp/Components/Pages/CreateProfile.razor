@page "/create-profile"
@using BTNXProfileApp.Models
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Components.Forms
@using System.Linq.Expressions
@inject HttpClient Http
@inject NavigationManager NavigationManager

<div class="container mt-4">
    <h2>Create New Profile</h2>
    <EditForm EditContext="@editContext" OnValidSubmit="HandleValidSubmit" FormName="CreateProfileForm">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="form-group mb-3">
            <label for="firstName">First Name:</label>
            <InputText id="firstName" @bind="person.FirstName" @bind:event="oninput" class="form-control" />
            <ValidationMessage For="@(() => person.FirstName)" />
        </div>

        <div class="form-group mb-3">
            <label for="lastName">Last Name:</label>
            <InputText id="lastName" @bind="person.LastName" @bind:event="oninput" class="form-control" />
            <ValidationMessage For="@(() => person.LastName)" />
        </div>

        <div class="form-group mb-3">
            <label for="email">Email:</label>
            <InputText id="email" @bind="person.Email" @bind:event="oninput" class="form-control" />
            <ValidationMessage For="@(() => person.Email)" />
        </div>

        <div class="form-group mb-3">
            <label for="phoneNumber">Phone Number:</label>
            <InputText id="phoneNumber" @bind="person.PhoneNumber" @bind:event="oninput" class="form-control" />
            <ValidationMessage For="@(() => person.PhoneNumber)" />
        </div>

        <button type="submit" class="btn btn-primary">Create Profile</button>
        <button type="button" class="btn btn-secondary" @onclick="NavigateBack">Back to List</button>
    </EditForm>
</div>

@code {
    private Person person = new();
    private EditContext editContext;

    protected override void OnInitialized()
    {
        editContext = new EditContext(person);
        StateHasChanged();
    }

    private async Task HandleValidSubmit()
    {
        StateHasChanged();

        Console.WriteLine($"Submitting: {person.FirstName} {person.LastName}");

        try
        {
            var response = await Http.PostAsJsonAsync("api/person", person);
            if (response.IsSuccessStatusCode)
            {
                NavigationManager.NavigateTo("/");
            }
            else
            {
                 var errorContent = await response.Content.ReadAsStringAsync();
                 Console.WriteLine($"API Error: {response.StatusCode} - {errorContent}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error creating profile: {ex.Message}");
        }
    }

    private void NavigateBack()
    {
        NavigationManager.NavigateTo("/");
    }
} 